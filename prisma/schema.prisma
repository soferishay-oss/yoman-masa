// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id               String   @id @default(uuid())
  name             String
  logoUrl          String?
  slogan           String?
  themeConfig      Json?
  dominantDateMode String   @default("gregorian")
  studyYears       Int      @default(1)
  institutionType  String?  // e.g. "elementary", "highschool", "college"
  moderationLevel  Int      @default(3) // 1 to 5 (1=very permissive, 5=very strict)
  nameFormat       String   @default("last_first") // "last_first" or "first_last"
  enabledModules   Json?
  retentionPolicy  String?
  currentAcademicYearId String?
  currentAcademicYear AcademicYear? @relation("TenantCurrentYear", fields: [currentAcademicYearId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]
  groups           Group[]
  events           Event[]
  tasks            Task[]
  stations         Station[]
  contentEntries   ContentEntry[]
  customRoles      CustomRole[]
  moodChecks       MoodCheck[]
  staffAlerts      StaffAlert[]
  academicYears    AcademicYear[]
}

model User {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  fullName         String
  firstName        String?
  lastName         String?
  nationalId       String?  @unique
  phoneNumber      String?  @unique
  email            String?  @unique
  passwordHash     String
  role             String   // e.g. "student", "staff", "admin"
  subRole          String?
  customRoleId     String?
  customRole       CustomRole? @relation(fields: [customRoleId], references: [id])
  classId          String?
  class            Group?   @relation("UserClass", fields: [classId], references: [id])
  groupMemberships GroupMember[]
  managedGroups    Group[]  @relation("StaffManagedGroups")
  status           String   @default("active")
  avatarUrl        String?
  preferences      Json?    // e.g. { dominantDateMode: "hebrew" }
  createdAt        DateTime @default(now())
  lastLoginAt      DateTime?

  contentEntries   ContentEntry[]
  moodChecks       MoodCheck[]
  createdTasks     Task[]
  taskAssignments  TaskAssignment[]
  createdEvents    Event[]
  eventRsvps       EventRSVP[]
  authoredLetters  Letter[] @relation("AuthoredLetters")
  receivedLetters  Letter[] @relation("ReceivedLetters")
}

model Group {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  name             String
  type             String   // e.g. "class" | "group"
  description      String?
  createdAt        DateTime @default(now())
  classUsers       User[]   @relation("UserClass")
  groupMembers     GroupMember[]
  managers         User[]   @relation("StaffManagedGroups")
  yearHistories    GroupYearHistory[]
}

model GroupMember {
  id               String   @id @default(uuid())
  userId           String
  groupId          String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group            Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  isDutyStudent    Boolean  @default(false)
  dutyRoleId       String?
  joinedAt         DateTime @default(now())

  @@unique([userId, groupId])
}

model ContentEntry {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  ownerUserId      String
  ownerUser        User     @relation(fields: [ownerUserId], references: [id])
  title            String?
  bodyText         String?
  type             String   // e.g. "journal", "note"
  category         String?
  tags             Json?
  mediaUrls        Json?
  aiTranscription  String?
  aiThought        String?
  visibility       String   @default("private")
  sharedWith       Json?
  status           String   @default("draft")
  versionNumber    Int      @default(1)
  parentEntryId    String?
  isVault          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  submittedAt      DateTime?
  lockedAt         DateTime?
}

model Task {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  creatorUserId    String
  creatorUser      User     @relation(fields: [creatorUserId], references: [id])
  
  title            String
  type             String   // e.g. "short_message", "long_message", "checklist"
  content          String?  
  mediaUrls        Json?
  checklistItems   Json?    
  
  requireCompletion Boolean @default(true)
  timerDeadline    DateTime?
  dateMode         String   @default("gregorian")
  
  isArchived       Boolean  @default(false)
  archiveType      String?  // e.g. "private", "public"
  linkedEventId    String?
  relativeDaysToEvent Int?
  
  status           String   @default("open")
  targetAudience   Json?    
  createdAt        DateTime @default(now())
  
  assignments      TaskAssignment[]
}

model TaskAssignment {
  id               String   @id @default(uuid())
  taskId           String
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status           String   @default("assigned") // "assigned", "opened", "completed"
  checklistState   Json?    
  openedAt         DateTime?
  completedAt      DateTime?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@unique([taskId, userId])
}

model Station {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  name             String
  stationType      String
  isPrivate        Boolean  @default(false)
  dateMode         String
  scheduledDate    DateTime?
  linkedEventId    String?
  orderIndex       Int      @default(0)
  status           String   @default("active")
}

model MoodCheck {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  frequency        String
  ratingType       String
  ratingValue      Int
  explanation      String?
  trendStatus      String?
  createdAt        DateTime @default(now())
}

model Event {
  id               String      @id @default(uuid())
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  creatorId        String
  creator          User        @relation(fields: [creatorId], references: [id])
  title            String
  description      String?
  type             String?     // e.g., "שבת", "מסע", "יום חזון", "סיור סליחות", "אחר"
  subtitle         String?
  color            String?
  scheduledDate    DateTime?
  endDate          DateTime?
  dateMode         String      @default("gregorian")
  location         String?
  status           String      @default("upcoming")
  targetAudience   Json?       // {"type":"all"} or {"type":"classes","classIds":["..."]}
  showOnCalendar   Boolean     @default(true)
  createdAt        DateTime    @default(now())
  rsvps            EventRSVP[]
}

model EventRSVP {
  id               String   @id @default(uuid())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  status           String   @default("pending") // pending, attending, declined, present
  attendedAt       DateTime?
  createdAt        DateTime @default(now())
}

model Letter {
  id               String   @id @default(uuid())
  tenantId         String
  authorId         String
  author           User     @relation("AuthoredLetters", fields: [authorId], references: [id])
  recipientId      String
  recipient        User     @relation("ReceivedLetters", fields: [recipientId], references: [id])
  content          String
  mediaUrls        Json?
  aiTranscription  String?
  aiThought        String?
  reactions        Json?
  createdAt        DateTime @default(now())
}

model StaffAlert {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  type             String   // e.g., "message_rejected"
  content          String
  metadata         Json?
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())
}
model CustomRole {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  permissions String   // Stored as JSON array string, e.g. '["manage_events", "manage_settings"]'
  type        String   @default("staff") // "staff" or "duty_student"
  users       User[]

  @@unique([tenantId, name])
}

model AcademicYear {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String   // e.g. "תשפ״ה"
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean  @default(false)
  currentForTenants Tenant[] @relation("TenantCurrentYear")

  groupHistories GroupYearHistory[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, name])
}

model GroupYearHistory {
  id             String   @id @default(uuid())
  groupId        String
  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  groupName      String   // The name the group had in this year
  managerNames   String   // Snapshot string of manager names, e.g. "דוד הלוי, משה כהן"
  
  createdAt      DateTime @default(now())

  @@unique([groupId, academicYearId])
}
